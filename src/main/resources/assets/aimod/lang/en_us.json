  "commands.ai_bot.help.header": "===== AI Bot Commands =====",
  "commands.ai_bot.help.spawn": "/ai_bot spawn [name]              e.g. /ai_bot spawn miner1",
  "commands.ai_bot.help.select": "/ai_bot select <name>             e.g. /ai_bot select miner1 (sets default target)",
  "commands.ai_bot.help.status": "/ai_bot status [name]             e.g. /ai_bot status (all) or /ai_bot status miner1",
  "commands.ai_bot.help.task": "/ai_bot task <command>             e.g. /ai_bot task craft a diamond pickaxe (LLM cloud)",
  "commands.ai_bot.help.task_all": "/ai_bot task_all <command>        e.g. /ai_bot task_all chop trees",
  "commands.ai_bot.help.stop": "/ai_bot stop [name]                e.g. /ai_bot stop miner1",
  "commands.ai_bot.help.cancel": "/ai_bot cancel [name]             same as stop",
  "commands.ai_bot.help.pause": "/ai_bot pause [name]              e.g. /ai_bot pause miner1",
  "commands.ai_bot.help.resume": "/ai_bot resume [name]             e.g. /ai_bot resume miner1",
  "commands.ai_bot.help.remove": "/ai_bot remove <name>             e.g. /ai_bot remove miner1 (kills active bot)",
  "commands.ai_bot.help.goto": "/ai_bot goto <x> <y> <z>           e.g. /ai_bot goto ~10 ~ ~-5 (float coords, supports ~ ^)",
  "commands.ai_bot.help.mine": "/ai_bot mine <block> [count]        e.g. /ai_bot mine diamond_ore 5",
  "commands.ai_bot.help.gather": "/ai_bot gather <type> [count]      e.g. /ai_bot gather WOOD 16 (WOOD/STONE/DIRT/SAND/COBBLESTONE)",
  "commands.ai_bot.help.craft": "/ai_bot craft <item> [count]        e.g. /ai_bot craft diamond_pickaxe 1",
  "commands.ai_bot.help.follow": "/ai_bot follow <player>            e.g. /ai_bot follow nightfall",
  "commands.ai_bot.help.follow_bot": "/ai_bot follow_bot <bot> <player> e.g. /ai_bot follow_bot miner1 nightfall",
  "commands.ai_bot.help.give": "/ai_bot give <item> [count]         e.g. /ai_bot give diamond 3",
  "commands.ai_bot.help.equip": "/ai_bot equip <item>               e.g. /ai_bot equip diamond_chestplate",
  "commands.ai_bot.help.say": "/ai_bot say <message>                e.g. /ai_bot say Task complete!",
  "commands.ai_bot.help.inventory": "/ai_bot inventory [name]          e.g. /ai_bot inventory miner1",
  "commands.ai_bot.help.toggle": "/ai_bot toggle <feature>           e.g. /ai_bot toggle autoFish (autoFish/autoReplenish/autoReplace)",
  "commands.ai_bot.help.save": "/ai_bot save <name> [desc]          e.g. /ai_bot save miner1 Mining bot",
  "commands.ai_bot.help.load": "/ai_bot load <name>                e.g. /ai_bot load miner1",
